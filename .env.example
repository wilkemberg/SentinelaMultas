# Copie este arquivo para ".env" (mesma pasta do docker-compose.yml) e preencha.
# O "docker compose up" lê o ".env" automaticamente. Sem esse arquivo, o sistema
# sobe do mesmo jeito, mas em modo dev: sem consultar multas de verdade, sem IA
# e sem enviar notificação (cada serviço faz fallback e só loga um aviso).

# Troque por uma string aleatória de 32+ caracteres antes de expor a API além do localhost.
JWT_SECRET_KEY=ChangeThisToSomethingVerySecureAndLongEnough

# Token da Infosimples (consulta de multas DETRAN-RJ / Prefeitura-RJ / SENATRAN-PRF).
INFOSIMPLES_TOKEN=

# Chave da API da Anthropic (análise do CTB e geração de defesa).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Chave da Resend (envio de e-mail).
RESEND_API_KEY=
RESEND_REMETENTE=Sentinela <alertas@sentinela.app>

# Z-API (WhatsApp não-oficial, solução provisória até migrar para Meta Cloud API).
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
